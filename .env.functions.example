# Secrets consumed by the Phase 3 edge functions.
# Push to Supabase with: supabase secrets set --env-file supabase/.env

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform's cut in basis points (2000 = 20%). Used by settle-payout.
PLATFORM_FEE_BPS=2000
# Monthly Premium subscription price in cents. Used by
# create-premium-checkout-session.
PREMIUM_PRICE_CENTS=999

# Shared secret the admin dashboard / cron jobs send as the `x-admin-secret`
# header when calling admin-only functions (settle-payout,
# approve-availability, run-matching, reveal-match, resy-sniper,
# send-match-revealed, send-feedback-request). Generate a long random value
# — this is the only thing standing between "any authenticated user" and
# "admin" for those endpoints, since there's no admin role in auth.users yet.
ADMIN_FUNCTION_SECRET=

# Public app URL used for Stripe Connect refresh/return URLs and
# Resend email links.
APP_URL=https://tableforone.app

# Phase 2 additions (already referenced by run-matching, reveal-match,
# stripe-webhook; functions not shipped yet)
RESEND_API_KEY=
ADMIN_EMAIL=

# Resy Reservation Integration
RESY_API_KEY=
RESY_AUTH_TOKEN=
RESY_PAYMENT_METHOD_ID=
