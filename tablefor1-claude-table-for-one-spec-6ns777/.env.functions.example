# Secrets consumed by the Phase 3 edge functions.
# Push to Supabase with: supabase secrets set --env-file supabase/.env

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform's cut in basis points (2000 = 20%). Used by settle-payout.
PLATFORM_FEE_BPS=2000

# Public app URL used for Stripe Connect refresh/return URLs and
# Resend email links.
APP_URL=https://tableforone.app

# Phase 2 additions (already referenced by run-matching, reveal-match,
# stripe-webhook; functions not shipped yet)
RESEND_API_KEY=
ADMIN_EMAIL=

# Resy Reservation Integration
RESY_API_KEY=
RESY_AUTH_TOKEN=
RESY_PAYMENT_METHOD_ID=
